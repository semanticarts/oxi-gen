prefix : <https://test.com/d/>
construct {
    ?id_iri
        a :Item ;
        :prefLabel ?pref_label ;
        :altLabel ?alt_label ;
        :hasSuccessor ?successor_iri
        .
}
where {
    BIND(tarql:expandPrefixedName(?id) AS ?id_iri)
    BIND(tarql:expandPrefixedName(?successor) AS ?successor_iri)
}
